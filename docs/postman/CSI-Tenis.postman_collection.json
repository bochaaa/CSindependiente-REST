            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requester_name\": \"Pedro Rodriguez\",\n  \"requester_phone\": \"2302123456\",\n  \"reason\": \"No podemos asistir\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/reservations/{{reservation_id}}/request-cancellation/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reservations",
                "{{reservation_id}}",
                "request-cancellation",
                ""
              ]
            },
            "description": "Solicita cancelacion hasta 3 horas antes del turno. Publico (20/min)."
          }
        }
      ]
