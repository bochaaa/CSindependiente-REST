              "query": [
                {
                  "key": "date",
                  "value": "{{target_date}}"
                }
              ]
            },
            "description": "Disponibilidad por fecha. Publico (20/min)."
          }
        },
        {
          "name": "POST /api/reservations/ (SINGLES)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"court\": 1,\n  \"date\": \"{{target_date}}\",\n  \"start_time\": \"18:00\",\n  \"game_mode\": \"SINGLES\",\n  \"contact_name\": \"Pedro Rodriguez\",\n  \"contact_phone\": \"2302123456\",\n  \"players\": [\n    {\n      \"first_name\": \"Pedro\",\n      \"last_name\": \"Rodriguez\",\n      \"is_member\": true\n    },\n    {\n      \"first_name\": \"Santi\",\n      \"last_name\": \"Fernandez\",\n      \"is_member\": false\n    }\n  ],\n  \"notes\": \"Reserva desde Postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/reservations/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reservations",
                ""
              ]
            },
            "description": "Crea reserva normal de 90 minutos. Publico (20/min)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  if (data.id) {",
                  "    pm.collectionVariables.set('reservation_id', String(data.id));",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/reservations/{id}/request-cancellation/",
          "request": {
            "method": "POST",
            "header": [
